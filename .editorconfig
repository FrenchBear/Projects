# Référence:
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/code-style-rule-options

[*.cs]

# Default severity for all analyzer diagnostics
dotnet_analyzer_diagnostic.severity = warning

# IDE0210: Convert to top-level statements
dotnet_diagnostic.IDE0210.severity = none

# IDE0040: Add accessibility modifiers
dotnet_diagnostic.IDE0040.severity = none

# CA1051: Do not declare visible instance fields
dotnet_diagnostic.CA1051.severity = none

# IDE0008: Use explicit type
dotnet_diagnostic.IDE0008.severity = none

# CA1707: Identifiers should not contain underscores
dotnet_diagnostic.CA1707.severity = none

# CA1309: Use ordinal string comparison
dotnet_diagnostic.CA1309.severity = none

# IDE0058: Expression value is never used
dotnet_diagnostic.IDE0058.severity = none

# CA1304: Specify CultureInfo
dotnet_diagnostic.CA1304.severity = none

# CA1311: Specify a culture or use an invariant version
dotnet_diagnostic.CA1311.severity = none

# CA1710: Identifiers should have correct suffix
dotnet_diagnostic.CA1710.severity = none

# CA1305: Specify IFormatProvider
dotnet_diagnostic.CA1305.severity = none

# IDE0060: Remove unused parameter
dotnet_diagnostic.IDE0060.severity = none

# CA2201: Exception System.Exception is not sufficiently specific
dotnet_diagnostic.CA2201.severity = none

# IDE0010: Populate switch
dotnet_diagnostic.IDE0010.severity = none

# CA1310: string.StartsWith...
dotnet_diagnostic.CA1310.severity = none

# CA1711: rename xxxEventHandler
dotnet_diagnostic.CA1711.severity = none

# CA5369: Deserialize overload is not safe
dotnet_diagnostic.CA5369.severity = none

# CA1838: Avoid StringBuilder parameters for P/Invokes
dotnet_diagnostic.CA1838.severity = none

# IDE0011: Add braces
csharp_prefer_braces = false

# IDE0306 Simplify collection initialization
# IDE0028 Simplify collection initialization
dotnet_diagnostic.IDE0306.severity = none
dotnet_diagnostic.IDE0028.severity = none

# Code-block preferences
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_expression_bodied_methods = true:none

# Expression-bodied members
csharp_style_expression_bodied_accessors = true
csharp_style_expression_bodied_constructors = true
csharp_style_expression_bodied_indexers = true
csharp_style_expression_bodied_lambdas = true
csharp_style_expression_bodied_local_functions = true
csharp_style_expression_bodied_methods = true
csharp_style_expression_bodied_operators = true
csharp_style_expression_bodied_properties = true

# IDE0048: Parentheses should be added for clarity
dotnet_style_parentheses_in_arithmetic_binary_operators = never_if_unnecessary

# dotnet_style_parentheses_in_other_binary_operators = never_if_unnecessary
# dotnet_style_parentheses_in_other_operators = never_if_unnecessary
# dotnet_style_parentheses_in_relational_binary_operators = never_if_unnecessary

# Space preferences
csharp_space_before_colon_in_inheritance_clause = false
