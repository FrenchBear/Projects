<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<UseWPF>true</UseWPF>
		<ApplicationManifest>app.manifest</ApplicationManifest>
		<ApplicationIcon>Resources\AppIcon.ico</ApplicationIcon>
		<Authors>Pierre Violent</Authors>
		<Copyright>Copyright ©Pierre Violent 2019-2026</Copyright>
		<Description>A simple WPF version of Solitaire classic card game with a solver (Net10 C#14)</Description>
		<Version>1.4.0</Version>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<!-- Application icon and specific resources -->
	<ItemGroup>
		<Resource Include="Resources\AppIcon.ico" />
		<Resource Include="Resources\Error24x24.png" />
	</ItemGroup>

	<ItemGroup>
		<None Remove="NewGameOptionsWindow.xaml" />
		<None Remove="ValidationError.16x16.png" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SolLib\SolLib.csproj" />
	</ItemGroup>

</Project>